{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DTF Pro Studio",
  "version": "0.4.5",
  "identifier": "com.dtfwana.prostudio",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js --host 127.0.0.1 --port 1420 --strictPort",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "node node_modules/typescript/bin/tsc -b --pretty false && node node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DTF Pro Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 560,
        "minHeight": 480,
        "center": true,
        "resizable": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": {
      "../models/background-removal/birefnet-lite.onnx": "models/background-removal/birefnet-lite.onnx",
      "../models/background-removal/model.json": "models/background-removal/model.json",
      "../models/background-removal/runtime/onnxruntime.dll": "models/background-removal/runtime/onnxruntime.dll",
      "../models/background-removal/runtime/onnxruntime_providers_shared.dll": "models/background-removal/runtime/onnxruntime_providers_shared.dll",
      "../models/background-removal/runtime/DirectML.dll": "models/background-removal/runtime/DirectML.dll"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGQkY5NUVEMzVFNkExQTkKUldTcG9lWTE3WlcvL3lGSVdUaVFLNU9Na21wMVR4TnJQK01mdWJJamRpclpJNGg5ZUV2VUZOZmMK",
      "endpoints": [
        "https://github.com/Lucasleiva1/dtf-wana/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
